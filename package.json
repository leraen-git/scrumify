{
  "name": "scrumify-monorepo",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "concurrently \"npm run start:dev -w apps/api\" \"npm run dev -w apps/web\"",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:migrate": "npm run prisma:migrate -w apps/api",
    "db:generate": "npm run prisma:generate -w apps/api"
  },
  "devDependencies": {
    "concurrently": "^9.1.2",
    "puppeteer-core": "^24.40.0"
  }
}
